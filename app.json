{
  "expo": {
    "name": "Guard Patrol Scanner",
    "slug": "guard-qr-scanner-app",
    "description": "QR-based hourly patrol scanner for Vihav Trade Center guards.",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/patrol-splash-logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/patrol-splash-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#17202a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.devrishabh.guardpatrolscanner"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/patrol-splash-logo.png",
        "backgroundColor": "#17202a"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA"
      ],
      "package": "com.devrishabh.guardpatrolscanner"
    },
    "web": {
      "favicon": "./assets/patrol-splash-logo.png"
    },
    "plugins": []
  }
}
